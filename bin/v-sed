#!/bin/bash
# info: calling vesta_sed PHP function
# options: PARAMETERS
#
# The function is calling Vesta PHP replacement for GNU 'sed' command (but without regular expression)

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#


if [ "$1" == "--stdin" ] && [ -p /dev/stdin ]; then
    STDIN=$(cat -)
    if [ ! -z "$STDIN" ]; then
        shift;
        echo "$STDIN" | php /usr/local/vesta/func/bash-to-php-interpreter.php '--stdin' 'vesta_sed' "$@"
        exit $?
    fi
fi

if [ "$1" == "--stdin" ]; then
    shift;
    php /usr/local/vesta/func/bash-to-php-interpreter.php '--stdin' 'vesta_sed' "$@"
else
    php /usr/local/vesta/func/bash-to-php-interpreter.php 'vesta_sed' "$@"
fi
exit $?
